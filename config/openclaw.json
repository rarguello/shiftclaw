{
  "models": {
    "mode": "merge",
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "openrouter/free", "name": "Free (auto-selected by OpenRouter)" }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/free"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true
    }
  }
}
