# SECRET TEMPLATE — do NOT commit a populated version of this file.
# This file shows the structure only. Create the real secret from a local .env file:
#
#   cp secret.yaml.template .env
#   # Edit .env with real values, then:
#   kubectl create secret generic shiftclaw \
#     --from-env-file=.env \
#     --namespace=shiftclaw \
#     --dry-run=client -o yaml | kubectl apply -f -
#
# Or imperatively:
#   kubectl create secret generic shiftclaw \
#     --from-literal=OPENROUTER_API_KEY=sk-or-... \
#     --from-literal=TELEGRAM_BOT_TOKEN=123456:ABC... \
#     --namespace=shiftclaw
#
# The .env file and any populated secret.yaml are in .gitignore — never commit them.

apiVersion: v1
kind: Secret
metadata:
  name: shiftclaw
  namespace: shiftclaw
  labels:
    app.kubernetes.io/name: shiftclaw
    app.kubernetes.io/component: secrets
type: Opaque
stringData:
  # Required: OpenRouter API key.
  # Get yours at https://openrouter.ai/settings/keys
  OPENROUTER_API_KEY: "REPLACE_ME"

  # Required: Telegram bot token from @BotFather.
  # /newbot → copy the token here.
  TELEGRAM_BOT_TOKEN: "REPLACE_ME"

  # Required: Gateway authentication token — pre-set to avoid regeneration on every restart.
  # Generate with: openssl rand -hex 32
  OPENCLAW_GATEWAY_TOKEN: "REPLACE_ME"
