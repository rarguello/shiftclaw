# Required: OpenRouter API key.
# Get yours at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-REPLACE_ME

# Required: Telegram bot token from @BotFather.
# /newbot → copy the token here.
TELEGRAM_BOT_TOKEN=123456789:REPLACE_ME

# Required: Gateway authentication token.
# Protects the HTTP gateway (port 18789) from unauthorized access.
# Generate a strong one with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME
